# Self-Hosted Supabase MCP Server — Environment Configuration
# Copy this file to .env and fill in your actual values

# Supabase Instance Configuration
SUPABASE_URL=https://your-domain.com
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_AUTH_JWT_SECRET=your-jwt-secret

# Direct Database Connection (for pg tools, transactions, auth management)
DATABASE_URL=postgresql://postgres:your-password@db:5432/postgres

# HTTP Transport (optional, for remote access)
# MCP_PORT=3100
# MCP_HOST=0.0.0.0

# Tool Whitelist (optional)
# MCP_TOOLS_CONFIG=./mcp-tools.json
